<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.roxi.charactercreator.controller.LoginController">
    <children>
        <AnchorPane layoutY="-1.0" prefHeight="409.0" prefWidth="602.0">
            <children>
                <Button fx:id="loginButton" layoutX="227.0" layoutY="258.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="25.0" prefWidth="149.0" text="Login" />

                <TextField fx:id="emailField" layoutX="227.0" layoutY="173.0" prefHeight="25.0" prefWidth="149.0" promptText="email" />

                <Label layoutX="159.0" layoutY="73.0" prefHeight="55.0" prefWidth="324.0" text="Login into your account">
                    <font>
                        <Font size="27.0" />
                    </font>
                </Label>

                <Label fx:id="statusLabel" layoutX="227.0" layoutY="290.0" prefWidth="149.0" textFill="RED" />
            <PasswordField fx:id="passwordField" layoutX="227.0" layoutY="216.0" />
           
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
